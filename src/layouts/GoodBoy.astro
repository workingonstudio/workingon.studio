---
import "../styles/good-boy.css";
import BaseLayout from "./BaseLayout.astro";
import { Font } from "astro:assets";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentURL = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout
  productName="Good Boy"
  seo={{
    title,
    description:
      "Get the praise you crave. The only Figma plugin you need to feel like you're doing a good job.",
    canonical: currentURL,
    ogImage: Astro.site + "good-boy/opengraph/site-default.webp",
    siteName: "goodboyplugin.com",
    twitterUrl: "https://goodboyplugin.com",
  }}
  meta={{
    themeColor: "#FFFFFF",
    faviconSvg: "/good-boy/favicon.svg",
    faviconPng: "/good-boy/favicon.png",
  }}
>
  <Fragment slot="head">
    <Font cssVariable="--font-oswald" preload />
    <Font cssVariable="--font-satoshi" preload />
  </Fragment>

  <slot />
</BaseLayout>
