---
import "../styles/is-figma-down.css";
import BaseLayout from "./BaseLayout.astro";
import { Font } from "astro:assets";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentURL = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout
  productName="Figma Down"
  seo={{
    title: `${title} - workingon.studio`,
    description: "The unofficial status of a well known SaaS product.",
    canonical: currentURL,
    siteName: "isfigmadown.com",
    twitterUrl: "https://isfigmadown.com",
  }}
  meta={{
    themeColor: "#020618",
    htmlClass: "scroll-smooth bg-[#1E1E1E]",
    faviconSvg: "/is-figma-down/favicon.svg",
  }}
>
  <Font slot="head" cssVariable="--font-inter" preload />

  <slot />
</BaseLayout>
