---
import "../styles/base.css";
import "../styles/main.css";

import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

import Analytics from "./partials/Analytics.astro";
import StructuredData from "./partials/StructuredData.astro";
import { AstroSeo } from "@astrolib/seo";

import Header from "@components/partials/Header.svelte";
import Footer from "@components/partials/Footer.svelte";

export interface Props {
  title: string;
  description?: string;
  fullHeight?: boolean;
}

const { title, description, fullHeight = true } = Astro.props;
const defaultDescription =
  "workingon.studio. Creative direction for founders and early-stage teams. In-house product development. Founded by Paul Mackenzie — 16 years, five acquisitions.";
const currentURL = new URL(Astro.url.pathname, Astro.site).href;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      function applyTheme() {
        const theme = localStorage.getItem("theme") || "light";
        const meta = document.querySelector('meta[name="theme-color"]');

        if (theme === "dark") {
          document.documentElement.classList.add("dark");
          if (meta) meta.setAttribute("content", "#030712");
        } else {
          document.documentElement.classList.remove("dark");
          if (meta) meta.setAttribute("content", "#f5f5f4");
        }
      }

      // Apply on initial load
      applyTheme();

      // Reapply after ClientRouter navigation
      document.addEventListener("astro:after-swap", applyTheme);
    </script>

    <ClientRouter />
    <Font cssVariable="--font-satoshi" preload />
    <Font cssVariable="--font-inter" preload />
    <AstroSeo
      {title}
      description={description || defaultDescription}
      canonical={currentURL}
      openGraph={{
        url: currentURL,
        title: title,
        description: description || defaultDescription,
        images: [
          {
            url: Astro.site + "site-default.webp",
            height: 630,
            width: 1200,
            alt: "Paul Mackenzie — Creative Director, workingon.studio",
          },
        ],
        site_name: "Paul Mackenzie",
        type: "website",
      }}
      twitter={{
        cardType: "summary_large_image",
        handle: "@prmack",
      }}
      ,
      additionalMetaTags={[
        {
          name: "twitter:image",
          content: Astro.site + "site-default.webp",
        },
      ]}
    />
    <meta name="theme-color" content="#030712" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <script
      is:inline
      type="module"
      src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"
    >
    </script>
    <meta name="generator" content={Astro.generator} />
    <Analytics />
    <StructuredData />
    <!-- CDN Font Stylesheets -->
    <title>{title}</title>
  </head>

  <body id="#top">
    <div class="bg-bg-main/98 border-surface-border sticky top-0 z-50 border-y backdrop-blur-sm">
      <div class="mx-auto w-full max-w-screen-2xl">
        <Header client:load {currentPath} />
      </div>
    </div>
    <div class="mx-auto w-full max-w-screen-2xl">
      <main
        class="border-surface-border mx-0 flex flex-1 flex-col border-x-0 md:mx-16 md:border-x"
        class:list={[{ "min-h-screen": fullHeight }]}
      >
        <div class="flex flex-1 flex-col justify-start">
          <slot />
        </div>
      </main>
    </div>
    <Footer client:visible />
  </body>
</html>
