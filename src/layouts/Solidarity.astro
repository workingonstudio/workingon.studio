---
import "../styles/solidarity.css";
import BaseLayout from "./BaseLayout.astro";
import { Font } from "astro:assets";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentURL = new URL(Astro.url.pathname, Astro.site).href;
const brockmannFontUrl = import.meta.env.BROCKMANN_FONT_CSS_URL;
---

<BaseLayout
  productName="Solidarity"
  seo={{
    title,
    description: "A Chrome Extension that makes you feel less s**t about looking for work.",
    canonical: currentURL,
    ogImage: Astro.site + "solidarity/opengraph/site-default.webp",
    ogImageAlt:
      "Solidarity - A Chrome Extension that makes you feel less s**t about looking for work.",
    siteName: "workingon.studio",
    twitterUrl: "https://wo.studio/projects/solidarity",
  }}
  meta={{
    themeColor: "#FAFAF9",
    adaptiveFavicons: {
      light: "/solidarity/favicon-light.svg",
      dark: "/solidarity/favicon-dark.svg",
    },
  }}
>
  <Fragment slot="head">
    <Font cssVariable="--font-satoshi" preload />
    <Font cssVariable="--font-zodiak" preload />
    {brockmannFontUrl && <link rel="stylesheet" href={brockmannFontUrl} />}
  </Fragment>

  <slot />
</BaseLayout>
