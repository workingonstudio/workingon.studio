---
import "../styles/tiny-wave.css";
import BaseLayout from "./BaseLayout.astro";
import { Font } from "astro:assets";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentURL = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout
  productName="TinyWave"
  seo={{
    title: `${title} - workingon.studio`,
    description: "Create waves with your voice.",
    canonical: currentURL,
    ogImage: `${Astro.site}tiny-wave/opengraph/site-default.webp`,
    ogImageAlt: "Tinywave - Create waves with your voice.",
    siteName: "workingon.studio",
    twitterUrl: "https://wo.studio/projects/tiny-wave",
  }}
  meta={{
    themeColor: "#FAFAF9",
    faviconSvg: "/tiny-wave/favicon.svg",
    bodyId: "top",
    bodyClass: "mx-[5%] h-full",
  }}
>
  <Font slot="head" cssVariable="--font-satoshi" preload />

  <slot />
</BaseLayout>
