---
import "../styles/dad-reply.css";
import BaseLayout from "./BaseLayout.astro";
import { Font } from "astro:assets";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentURL = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout
  productName="Dad Reply"
  seo={{
    title: `${title} - workingon.studio`,
    description: "One-click emoji replies for Gmail.",
    canonical: currentURL,
    ogImage: `${Astro.site}dad-reply/opengraph/site-default.webp`,
    ogImageAlt: "Dad Reply - Email replies without the email part",
    siteName: "dadreply.com",
    twitterUrl: "https://dadreply.com",
  }}
  meta={{
    themeColor: "#FFFFFF",
    htmlClass: "scroll-smooth bg-white",
    faviconPng: "/dad-reply/favicon.png",
    bodyId: "top",
  }}
>
  <Fragment slot="head">
    <Font cssVariable="--font-geist" preload />
    <Font cssVariable="--font-poppins" preload />
    <Font cssVariable="--font-roboto" preload />
  </Fragment>

  <slot />
</BaseLayout>
