---
import "../styles/glyph-palette.css";
import BaseLayout from "./BaseLayout.astro";
import { Font } from "astro:assets";

import Header from "@components/glyph-palette/Header.svelte";
import Footer from "@components/glyph-palette/Footer.svelte";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentURL = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout
  productName="Glyph Palette"
  seo={{
    title: `${title} - workingon.studio`,
    description:
      "Bring 100's of modern icon sets directly into your .sketch files, with full control over size, stroke, and color.",
    canonical: currentURL,
    ogImage: `${Astro.site}glyph-palette/opengraph/site-default.webp`,
    ogImageAlt: "Glyph Palette - A modern icon plugin for Sketch.",
    siteName: "glyphpalette.com",
    twitterUrl: "https://glyphpalette.com",
  }}
  meta={{
    themeColor: "#FAFAF9",
    faviconSvg: "/glyph-palette/favicon.svg",
    faviconPng: "/glyph-palette/favicon.png",
    bodyId: "top",
  }}
>
  <Fragment slot="head">
    <Font cssVariable="--font-cabinet-grotesk" preload />
    <Font cssVariable="--font-montserrat" preload />
    <Font cssVariable="--font-satoshi" preload />
    <!-- Font Awesome Kit — retained pending icon audit -->
    <script is:inline src="https://kit.fontawesome.com/180e1f6a33.js" crossorigin="anonymous">
    </script>
  </Fragment>

  <Header />
  <slot />
  <Footer client:visible />
</BaseLayout>
