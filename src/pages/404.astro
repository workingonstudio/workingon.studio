---
import Layout from "@layouts/Layout.astro";
---

<Layout title="404">
  <div class="flex h-dvh flex-col items-center gap-4 p-24">
    <h1 class="text-8xl!">404</h1>
    <p class="text-muted">Well this sucks.</p>
    <p class="text-muted text-center text-xs">
      Either you have hit a link that doesn't exist anymore. Or you're snooping around.
    </p>
    <a href="/" class="text-sm underline hover:no-underline">Go home</a>
  </div>
</Layout>

<style>
  @reference "../styles/main.css";
</style>
