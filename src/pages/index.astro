---
import Layout from "../layouts/Layout.astro";
import Home from "../components/Home.svelte";
import { getCollection } from "astro:content";

const posts = await getCollection("writing");
const sortedPosts = posts
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .map((post) => ({
    slug: post.slug,
    title: post.data.title,
    description: post.data.description,
  }));

const allProjects = await getCollection("projects");
const sortedProjects = allProjects
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((p) => ({
    slug: p.slug,
    title: p.data.title,
    description: p.data.description,
    link: p.data.link,
    externalLink: p.data.externalLink,
    image: p.data.image,
    featured: p.data.featured,
    publishedAt: p.data.publishedAt.toISOString(),
    download: p.data.download ?? null,
    body: p.rendered?.html ?? "",
  }));
---

<Layout title="workingon.studio - Digital tools that work. And make a point.">
  <Home articles={sortedPosts} projects={sortedProjects} client:load />
</Layout>
